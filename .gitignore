# Local .terraform directories
.terraform/
**/.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include tfvars files that are part of examples or templates, if desired
#!example.tfvars

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore editor swap/temp files
*.swp
*.swo
*~
